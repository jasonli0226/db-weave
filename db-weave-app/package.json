{
  "name": "db-weave-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "pnpm grammar:build && vite build && tsc",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "grammar:build": "peggy --format es -o src/lib/dsl/grammar/generated/parser.js src/lib/dsl/grammar/schema.peggy",
    "grammar:watch": "peggy --watch --format es -o src/lib/dsl/grammar/generated/parser.js src/lib/dsl/grammar/schema.peggy"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.15",
    "@clerk/clerk-react": "^5.59.6",
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-start": "^1.154.8",
    "@tanstack/router-plugin": "^1.132.0",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.46",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "elkjs": "^0.11.0",
    "html-to-image": "1.11.11",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.545.0",
    "monaco-editor": "^0.52.0",
    "nitro": "3.0.1-alpha.2",
    "node-sql-parser": "^5.4.0",
    "peggy": "^5.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.4.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.0.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.3.11",
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/dagre": "^0.7.53",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "prettier": "^3.5.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0"
  }
}
