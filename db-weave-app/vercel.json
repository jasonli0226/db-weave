{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm grammar:build && vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "git": {
    "deploymentEnabled": {
      "production": true
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "${VITE_API_URL}/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
